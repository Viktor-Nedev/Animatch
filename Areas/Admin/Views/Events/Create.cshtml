@model Animatch.Models.Event
@{
    ViewData["Title"] = "Създай събитие";
}

@section HeadStyles {
    <link rel="stylesheet" href="~/css/admin-events.css" asp-append-version="true" />
}

<div class="container mt-5 event-admin-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="page-title m-0">Ново събитие</h1>
        <a asp-area="Admin" asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Към събитията
        </a>
    </div>

    <div class="card h-100 event-form-card">
        <form asp-area="Admin" asp-controller="Events" asp-action="Create" method="post" class="card-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="event-form-grid">
                <div class="event-form-full">
                    <label asp-for="Title" class="event-form-label">Заглавие</label>
                    <input asp-for="Title" class="form-control" placeholder="Пример: Съботна разходка в Южния парк" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Date" class="event-form-label">Дата и час</label>
                    <input asp-for="Date" type="datetime-local" class="form-control" value='@((Model.Date == default ? DateTime.Now : Model.Date).ToString("yyyy-MM-ddTHH:mm"))' />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="Location" class="event-form-label">Локация</label>
                    <input asp-for="Location" class="form-control" placeholder="Пример: София, Южен парк" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="event-form-full">
                    <label asp-for="Description" class="event-form-label">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="6" placeholder="Добави детайли за инициативата, изисквания и как хората могат да помогнат."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="event-admin-actions">
                <button type="submit" class="btn btn-success">Запази събитие</button>
                <a asp-area="Admin" asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

