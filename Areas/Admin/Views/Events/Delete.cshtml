@model Animatch.Models.Event
@{
    ViewData["Title"] = "Изтриване на събитие";
}

@section HeadStyles {
    <link rel="stylesheet" href="~/css/admin-events.css" asp-append-version="true" />
}

<div class="container mt-5 event-admin-shell">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="page-title m-0">Изтриване на събитие</h1>
        <a asp-area="Admin" asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i> Към детайли
        </a>
    </div>

    <article class="card h-100 event-danger-card">
        <h4 class="event-danger-title">Ще бъде изтрито: @Model.Title</h4>
        <div class="event-meta">
            <div class="event-meta-item">
                <span class="event-meta-label">Дата</span>
                <span class="event-meta-value"><i class="far fa-calendar-alt me-1"></i>@Model.Date.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
            <div class="event-meta-item">
                <span class="event-meta-label">Локация</span>
                <span class="event-meta-value"><i class="fas fa-location-dot me-1"></i>@Model.Location</span>
            </div>
            @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
            {
                <div class="event-meta-item">
                    <span class="event-meta-label">Координати</span>
                    <span class="event-meta-value">@Model.Latitude.Value.ToString("F14"), @Model.Longitude.Value.ToString("F14")</span>
                </div>
            }
        </div>
        <div class="event-description">@Model.Description</div>

        <form asp-area="Admin" asp-controller="Events" asp-action="Delete" method="post" class="event-admin-actions">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Изтрий окончателно</button>
            <a asp-area="Admin" asp-controller="Events" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Отказ</a>
        </form>
    </article>
</div>

