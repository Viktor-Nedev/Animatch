@model Animatch.ViewModels.EventIndexQueryViewModel
@{
    ViewData["Title"] = "Събития";
    var now = DateTime.Now;
    var upcoming = Model.Events.Count(e => e.Date >= now);
    var thisWeek = Model.Events.Count(e => e.Date >= now && e.Date <= now.AddDays(7));
}

@section HeadStyles {
    <link rel="stylesheet" href="~/css/admin-events.css" asp-append-version="true" />
}

<div class="container mt-5 event-index">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <h1 class="page-title m-0">Доброволчески събития</h1>
        <a asp-area="Admin" asp-controller="Events" asp-action="Create" class="btn btn-success btn-lg">
            <i class="fas fa-plus-circle me-1"></i> Добави събитие
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100 event-stat-card">
                <div class="card-body">
                    <div class="event-stat-icon"><i class="fas fa-list-check"></i></div>
                    <div>
                        <p class="event-stat-label">Показани</p>
                        <h3 class="event-stat-value">@Model.Events.Count()</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 event-stat-card">
                <div class="card-body">
                    <div class="event-stat-icon"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <p class="event-stat-label">Предстоящи</p>
                        <h3 class="event-stat-value">@upcoming</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 event-stat-card">
                <div class="card-body">
                    <div class="event-stat-icon"><i class="fas fa-calendar-week"></i></div>
                    <div>
                        <p class="event-stat-label">До 7 дни</p>
                        <h3 class="event-stat-value">@thisWeek</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form method="get" asp-area="Admin" asp-controller="Events" asp-action="Index" class="card h-100 animal-filters event-filters mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-5">
                    <label class="form-label fw-semibold" for="searchTerm">Заглавие</label>
                    <input id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Търси по заглавие..." />
                </div>
                <div class="col-lg-5">
                    <label class="form-label fw-semibold" for="location">Локация</label>
                    <input id="location" name="location" value="@Model.Location" class="form-control" placeholder="Търси по локация..." />
                </div>
                <div class="col-lg-2">
                    <label class="form-label fw-semibold" for="pageSize">На страница</label>
                    <select id="pageSize" name="pageSize" class="form-select">
                        @if (Model.PageSize == 3)
                        {
                            <option value="3" selected>3</option>
                        }
                        else
                        {
                            <option value="3">3</option>
                        }
                        @if (Model.PageSize == 6)
                        {
                            <option value="6" selected>6</option>
                        }
                        else
                        {
                            <option value="6">6</option>
                        }
                        @if (Model.PageSize == 9)
                        {
                            <option value="9" selected>9</option>
                        }
                        else
                        {
                            <option value="9">9</option>
                        }
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3 flex-wrap">
                <button type="submit" class="btn btn-success">Филтрирай</button>
                <button type="button" id="loadEventsApiBtn" class="btn btn-outline-primary">Филтрирай (AJAX)</button>
                <a asp-area="Admin" asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
            </div>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">@TempData["Success"]</div>
    }

    <div id="eventsGrid" class="row g-3">
        @if (!Model.Events.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center p-5">
                    <i class="fas fa-calendar-xmark fa-3x mb-3"></i>
                    <h4>Няма събития за избраните филтри</h4>
                    <p class="mb-3">Промени филтрите или добави ново събитие.</p>
                    <a asp-area="Admin" asp-controller="Events" asp-action="Create" class="btn btn-success">Добави събитие</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var ev in Model.Events)
            {
                <partial name="_EventCard" model="ev" />
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Events pagination" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Events"
                       asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-location="@Model.Location"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize">Назад</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(Model.Page == i ? "active" : "")">
                        <a class="page-link"
                           asp-area="Admin"
                           asp-controller="Events"
                           asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-location="@Model.Location"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Events"
                       asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-location="@Model.Location"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize">Напред</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        (() => {
            const button = document.getElementById('loadEventsApiBtn');
            const form = button?.closest('form');
            const grid = document.getElementById('eventsGrid');

            if (!button || !form || !grid) {
                return;
            }

            const formatDate = (dateRaw) => {
                if (!dateRaw) {
                    return '';
                }

                const date = new Date(dateRaw);
                return date.toLocaleString('bg-BG', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            };

            const createEventCard = (eventItem) => {
                const id = eventItem.id ?? eventItem.Id;
                const titleText = eventItem.title ?? eventItem.Title ?? '';
                const descriptionText = eventItem.description ?? eventItem.Description ?? '';
                const locationText = eventItem.location ?? eventItem.Location ?? '';
                const dateRaw = eventItem.date ?? eventItem.Date;
                const dateText = formatDate(dateRaw);
                const shortened = descriptionText.length > 140 ? `${descriptionText.substring(0, 140)}...` : descriptionText;
                const encodedLocation = encodeURIComponent(locationText);

                const col = document.createElement('div');
                col.className = 'col-xl-4 col-md-6';
                col.innerHTML = `
<div class="card h-100 event-card">
    <div class="event-card-top">
        <span class="event-card__date"><i class="far fa-calendar-alt"></i>${dateText}</span>
        <span class="event-card__badge"><i class="fas fa-hand-holding-heart me-1"></i>Инициатива</span>
    </div>
    <div class="card-body">
        <h4 class="card-title mb-3 text-success">${titleText}</h4>
        <p class="card-text mb-2 event-card__location"><i class="fas fa-location-dot"></i><strong>${locationText}</strong></p>
        <p class="card-text event-card__description">${shortened}</p>
    </div>
    <div class="card-footer bg-white border-0 pb-3 px-3">
        <div class="event-card__actions">
            <a class="btn btn-success btn-sm" href="/Admin/Events/Details/${id}">Детайли</a>
            <a class="btn btn-outline-primary btn-sm" href="/Admin/Events/Edit/${id}">Редакция</a>
            <a class="btn btn-outline-danger btn-sm" href="/Admin/Events/Delete/${id}">Изтриване</a>
            <a class="btn btn-outline-success btn-sm" target="_blank" rel="noopener noreferrer" href="https://www.google.com/maps/search/?api=1&query=${encodedLocation}">Карта</a>
        </div>
    </div>
</div>`;
                return col;
            };

            button.addEventListener('click', async () => {
                const formData = new FormData(form);
                const params = new URLSearchParams();
                const searchTerm = (formData.get('searchTerm') ?? '').toString();
                const location = (formData.get('location') ?? '').toString();
                const pageSize = (formData.get('pageSize') ?? '6').toString();

                if (searchTerm) {
                    params.set('searchTerm', searchTerm);
                }
                if (location) {
                    params.set('location', location);
                }
                params.set('page', '1');
                params.set('pageSize', pageSize);

                try {
                    const response = await fetch(`/api/events?${params.toString()}`, {
                        headers: { 'Accept': 'application/json' }
                    });

                    if (!response.ok) {
                        throw new Error('Cannot load events');
                    }

                    const payload = await response.json();
                    const items = payload.items ?? payload.Items ?? [];
                    grid.innerHTML = '';

                    if (!items.length) {
                        const col = document.createElement('div');
                        col.className = 'col-12';
                        col.innerHTML = '<div class="alert alert-info text-center p-5"><h4>Няма събития за избраните филтри</h4></div>';
                        grid.appendChild(col);
                    } else {
                        items.forEach(item => grid.appendChild(createEventCard(item)));
                    }
                } catch (error) {
                    console.error(error);
                }
            });
        })();
    </script>
}
