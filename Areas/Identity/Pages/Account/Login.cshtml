@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-shell">
    <div class="auth-card fade-in">
        <div class="auth-header">
            <p class="auth-kicker">Animatch</p>
            <h1>@ViewData["Title"]</h1>
            <p class="auth-subtitle">Добре дошъл обратно! Влез, за да продължиш към платформата.</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Login" class="form-control" autocomplete="username" aria-required="true" placeholder="email или username" />
                <label asp-for="Input.Login" class="form-label">Email или Username</label>
                <span asp-validation-for="Input.Login" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="form-label">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="checkbox mb-3">
                <label asp-for="Input.RememberMe" class="form-label">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>
            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
            <p class="auth-footer">
                Нямаш акаунт?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Регистрирай се</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
