@model Animatch.ViewModels.MyWalkRequestsViewModel
@{
    ViewData["Title"] = "Моите заявки";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Моите заявки</h2>
        <a asp-controller="Animal" asp-action="Index" class="btn btn-outline-secondary">Към обявите</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light fw-bold">Изпратени от мен</div>
        <div class="card-body p-0">
            @if (!Model.CreatedRequests.Any())
            {
                <div class="p-3 text-muted">Нямаш изпратени заявки.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Животно</th>
                                <th>Дата</th>
                                <th>Статус</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.CreatedRequests)
                            {
                                <tr>
                                    <td>@request.Animal.Name</td>
                                    <td>@request.RequestedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (request.Status == Animatch.Models.RequestStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Чакаща</span>
                                        }
                                        else if (request.Status == Animatch.Models.RequestStatus.Approved)
                                        {
                                            <span class="badge bg-success">Одобрена</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Отхвърлена</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-outline-primary btn-sm">Детайли</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light fw-bold">Заявки към моите обяви @(Model.IsAdmin ? "(Админ изглед)" : "")</div>
        <div class="card-body p-0">
            @if (!Model.IncomingRequests.Any())
            {
                <div class="p-3 text-muted">Няма входящи заявки.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Животно</th>
                                <th>Потребител</th>
                                <th>Дата</th>
                                <th>Статус</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.IncomingRequests)
                            {
                                <tr>
                                    <td>@request.Animal.Name</td>
                                    <td>@request.RequesterId</td>
                                    <td>@request.RequestedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (request.Status == Animatch.Models.RequestStatus.Pending)
                                        {
                                            <span class="badge bg-warning text-dark">Чакаща</span>
                                        }
                                        else if (request.Status == Animatch.Models.RequestStatus.Approved)
                                        {
                                            <span class="badge bg-success">Одобрена</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Отхвърлена</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-outline-primary btn-sm">Детайли</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
