@model Animatch.Models.WalkRequest
@{
    ViewData["Title"] = "Детайли на заявка";
    var canManage = User.IsInRole("Administrator") || Model.Animal.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container mt-4">
    <div class="card border-0 shadow-lg">
        <div class="card-header bg-success text-white py-3 d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Детайли на заявка</h3>
            @if (Model.Status == Animatch.Models.RequestStatus.Pending)
            {
                <span class="badge bg-warning text-dark">Чакаща</span>
            }
            else if (Model.Status == Animatch.Models.RequestStatus.Approved)
            {
                <span class="badge bg-light text-success">Одобрена</span>
            }
            else
            {
                <span class="badge bg-light text-danger">Отхвърлена</span>
            }
        </div>
        <div class="card-body p-4">
            <dl class="row mb-4">
                <dt class="col-sm-3">Животно</dt>
                <dd class="col-sm-9">@Model.Animal.Name</dd>

                <dt class="col-sm-3">Категория</dt>
                <dd class="col-sm-9">@Model.Animal.Category?.Name</dd>

                <dt class="col-sm-3">Град</dt>
                <dd class="col-sm-9">@Model.Animal.Town</dd>

                <dt class="col-sm-3">Потребител</dt>
                <dd class="col-sm-9">@Model.RequesterId</dd>

                <dt class="col-sm-3">Подадена на</dt>
                <dd class="col-sm-9">@Model.RequestedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>

            <div class="mb-4">
                <h5 class="fw-bold">Съобщение</h5>
                <div class="p-3 bg-light rounded-3">
                    @(string.IsNullOrWhiteSpace(Model.Message) ? "Няма съобщение." : Model.Message)
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (canManage && Model.Status == Animatch.Models.RequestStatus.Pending)
                {
                    <form asp-action="Approve" method="post" asp-antiforgery="true">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success">Одобри</button>
                    </form>
                    <form asp-action="Reject" method="post" asp-antiforgery="true">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">Отхвърли</button>
                    </form>
                }
                <a asp-action="MyRequests" class="btn btn-outline-secondary">Назад към заявките</a>
                <a asp-controller="Animal" asp-action="Details" asp-route-id="@Model.AnimalId" class="btn btn-outline-primary">Към животното</a>
            </div>
        </div>
    </div>
</div>
