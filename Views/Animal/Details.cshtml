@model Animatch.ViewModels.AnimalDetailsViewModel

@{
    ViewData["Title"] = $"{Model.Name} - Детайли";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isOwner = !string.IsNullOrEmpty(currentUserId) && Model.OwnerId == currentUserId;
    var isAdmin = User.IsInRole("Administrator");
}

<div class="container mt-5 fade-in">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card shadow-lg border-0 overflow-hidden">
                <div class="card-header bg-success text-white py-4 position-relative" 
                     style="background: linear-gradient(135deg, #198754, #20c997) !important;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="display-5 fw-bold mb-0">@Model.Name</h1>
                            <p class="lead mb-0 opacity-75">
                                @Model.Species
                            </p>
                        </div>
                        <span class="badge bg-white text-success fs-5 px-3 py-2 rounded-pill shadow-sm">
                            @Model.CategoryName
                        </span>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <div class="mb-4">
                            <img src="@Model.ImageUrl" class="animal-details__image rounded" style="width: 100%; object-fit: cover; max-height: 400px;" alt="Снимка на @Model.Name" />
                        </div>
                    }

                    <div class="row g-4 mb-5">
                        <div class="col-sm-6">
                            <div class="p-3 border-start border-4 border-success bg-light rounded-end h-100">
                                <h5 class="text-success fw-bold mb-2">
                                    <i class="bi bi-geo-alt-fill me-2"></i> Местоположение
                                </h5>
                                <p class="fs-5 mb-0">@(Model.Town ?? "Не е посочено")</p>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 border-start border-4 border-success bg-light rounded-end h-100">
                                <h5 class="text-success fw-bold mb-2">
                                    <i class="bi bi-patch-check-fill me-2"></i> Порода
                                </h5>
                                <p class="fs-5 mb-0">@(Model.Breed ?? "Смесена/Неизвестна")</p>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="p-3 border-start border-4 border-success bg-light rounded-end h-100">
                                <h5 class="text-success fw-bold mb-2">
                                    <i class="bi bi-telephone-fill me-2"></i> Телефон
                                </h5>
                                <p class="fs-5 mb-0">@Model.PhoneNumber</p>
                            </div>
                        </div>

                        @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                        {
                            <div class="col-sm-6">
                                <div class="p-3 border-start border-4 border-warning bg-light rounded-end h-100">
                                    <h5 class="text-warning fw-bold mb-2">
                                        <i class="bi bi-pin-map-fill me-2"></i> Кординати
                                    </h5>
                                    <p class="fs-6 mb-0">Lat: @Model.Latitude, Lng: @Model.Longitude</p>
                                    <a asp-action="Map" class="small text-decoration-none">Виж на картата</a>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mb-5">
                        <h4 class="page-title mb-4">Разкажи ми повече</h4>
                        <div class="p-4 bg-white border rounded-3 shadow-sm">
                            <p class="fs-5 lh-base text-secondary mb-0" style="white-space: pre-line;">
                                @Model.Description
                            </p>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-3 mt-4 pt-4 border-top">
                        @if (User.Identity?.IsAuthenticated == true && !isOwner)
                        {
                            <a asp-controller="Requests" asp-action="Create" asp-route-animalId="@Model.Id" class="btn btn-success btn-lg px-4 shadow-sm">
                                <i class="bi bi-send-plus me-2"></i> Изпрати заявка
                            </a>
                        }
                        @if (isOwner || isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-lg px-4 shadow-sm">
                                <i class="bi bi-pencil-square me-2"></i> Редактирай
                            </a>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-arrow-left me-2"></i> Назад към списъка
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 text-center pb-5">
                <p class="text-muted italic">Чудесно е, че търсите приятел за вашето животно!</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
