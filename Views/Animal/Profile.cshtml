@model Animatch.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Моят Профил";
}

<div class="container mt-5 fade-in">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-lg border-0 text-center p-5 h-100 position-relative overflow-hidden" 
                 style="border-radius: 30px; background: linear-gradient(145deg, #ffffff, #f8f9fa);">
                
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-success opacity-0 hover-bg-show"></div>

                <div class="mb-4">
                    <div class="rounded-circle shadow-sm border border-5 border-white mx-auto d-flex align-items-center justify-content-center text-white" 
                         style="width: 120px; height: 120px; font-size: 50px; background: linear-gradient(135deg, #198754, #20c997);">
                        @(Model.Username.Length > 0 ? Model.Username[0].ToString().ToUpper() : "U")
                    </div>
                </div>

                <h2 class="fw-bold text-dark mb-1">@Model.Username</h2>
                <p class="text-muted small mb-4">@Model.Email</p>
                
                <div class="p-3 bg-light rounded-4 mb-4">
                    <span class="d-block text-uppercase text-muted fw-bold style-lh-1" style="font-size: 0.7rem;">Обяви</span>
                    <span class="fs-2 fw-bold text-success">@Model.MyAnimals.Count()</span>
                </div>

                <div class="d-grid gap-2">
                    <a asp-action="Create" class="btn btn-success btn-lg rounded-pill shadow-sm py-3 fw-bold">
                        <i class="fas fa-plus-circle me-2"></i> Нова обява
                    </a>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 p-4 h-100" style="border-radius: 30px;">
                <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                    <h3 class="fw-bold mb-0">Моите обяви</h3>
                    @if (Model.MyAnimals.Any())
                    {
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">Активни</span>
                    }
                </div>
                
                @if (!Model.MyAnimals.Any())
                {
                    <div class="text-center py-5">
                        <div class="mb-4 text-muted opacity-25">
                            <i class="fas fa-paw fa-5x"></i>
                        </div>
                        <h5 class="text-muted">Все още нямате публикувани животни.</h5>
                        <p class="text-secondary small mb-4">Споделете информация за вашето животно и му намерете нови приятели!</p>
                        <a asp-action="Create" class="btn btn-outline-success rounded-pill px-5 py-3 fw-bold">
                            Направи първата обява
                        </a>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var animal in Model.MyAnimals.OrderByDescending(a => a.Id))
                        {
                            <div class="col-12">
                                <div class="card border-0 shadow-sm animal-row-hover h-100 overflow-hidden" 
                                     style="border-radius: 20px; transition: transform 0.2s;">
                                    <div class="row g-0 align-items-center">
                                        <div class="col-4 col-md-3 p-2">
                                            <div class="rounded-4 overflow-hidden" style="height: 120px;">
                                                @if (!string.IsNullOrEmpty(animal.ImageUrl))
                                                {
                                                    <img src="@animal.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@animal.Name">
                                                }
                                                else
                                                {
                                                    <div class="bg-light h-100 w-100 d-flex align-items-center justify-content-center text-muted">
                                                        <i class="fas fa-paw fa-2x opacity-25"></i>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                        <div class="col-8 col-md-9 p-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h5 class="fw-bold text-dark mb-1">@animal.Name</h5>
                                                    <div class="d-flex gap-2 align-items-center">
                                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2">@animal.Category?.Name</span>
                                                        <span class="text-muted small"><i class="fas fa-map-marker-alt me-1"></i> @animal.Town</span>
                                                    </div>
                                                </div>
                                                
                                                <div class="btn-group">
                                                    <button type="button" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center" 
                                                            style="width: 35px; height: 35px;" data-bs-toggle="dropdown">
                                                        <i class="fas fa-ellipsis-v text-muted"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2">
                                                        <li>
                                                            <a class="dropdown-item py-2 rounded-3" asp-action="Edit" asp-route-id="@animal.Id">
                                                                <i class="fas fa-edit me-2 text-warning"></i> Редактирай
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a class="dropdown-item py-2 rounded-3" asp-action="Details" asp-route-id="@animal.Id">
                                                                    <i class="fas fa-eye me-2 text-primary"></i> Виж детайли
                                                            </a>
                                                        </li>
                                                        <li><hr class="dropdown-divider"></li>
                                                        <li>
                                                            <a class="dropdown-item py-2 rounded-3 text-danger" asp-action="Delete" asp-route-id="@animal.Id">
                                                                <i class="fas fa-trash me-2"></i> Изтрий
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .animal-row-hover:hover {
        transform: translateX(10px);
        background-color: #fcfcfc;
    }
    .style-lh-1 { line-height: 1; }
    .object-fit-cover { object-fit: cover; }
    .fade-in {
        animation: fadeIn 0.5s ease-in;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
