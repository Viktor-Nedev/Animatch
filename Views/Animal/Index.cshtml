@using System.Security.Claims
@model Animatch.ViewModels.AnimalIndexQueryViewModel

@{
    ViewData["Title"] = "Всички животни";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5 animal-index">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title m-0">Всички животни</h1>
        <a asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle"></i> Добави ново
        </a>
    </div>

    <form method="get" asp-action="Index" class="card h-100 animal-filters mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label for="searchTerm" class="form-label fw-semibold">Име</label>
                    <input type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Търси по име..." />
                </div>
                <div class="col-lg-3">
                    <label for="categoryId" class="form-label fw-semibold">Категория</label>
                    <select id="categoryId" name="categoryId" class="form-select">
                        <option value="">Всички категории</option>
                        @foreach (var category in Model.Categories)
                        {
                            if (Model.CategoryId == category.Id)
                            {
                                <option value="@category.Id" selected>@category.Name</option>
                            }
                            else
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-3">
                    <label for="town" class="form-label fw-semibold">Град</label>
                    <select id="town" name="town" class="form-select">
                        <option value="">Всички градове</option>
                        @foreach (var town in Model.Towns)
                        {
                            if (Model.Town == town)
                            {
                                <option value="@town" selected>@town</option>
                            }
                            else
                            {
                                <option value="@town">@town</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label for="pageSize" class="form-label fw-semibold">На страница</label>
                    <select id="pageSize" name="pageSize" class="form-select">
                        @if (Model.PageSize == 6)
                        {
                            <option value="6" selected>6</option>
                        }
                        else
                        {
                            <option value="6">6</option>
                        }
                        @if (Model.PageSize == 9)
                        {
                            <option value="9" selected>9</option>
                        }
                        else
                        {
                            <option value="9">9</option>
                        }
                        @if (Model.PageSize == 12)
                        {
                            <option value="12" selected>12</option>
                        }
                        else
                        {
                            <option value="12">12</option>
                        }
                    </select>
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-success">Филтрирай</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
            </div>
        </div>
    </form>

    @if (!Model.Animals.Any())
    {
        <div class="alert alert-info text-center p-5">
            <i class="bi bi-emoji-frown display-1"></i>
            <h3 class="mt-3">Няма резултати за избраните филтри</h3>
            <p>Промени търсенето или добави ново животно.</p>
            <a asp-action="Create" class="btn btn-success btn-lg mt-3">
                <i class="bi bi-plus-circle"></i> Добави животно
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var animal in Model.Animals)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100">
                        @if (!string.IsNullOrWhiteSpace(animal.ImageUrl))
                        {
                            <img src="@animal.ImageUrl" class="card-img-top animal-card__image" alt="Снимка на @animal.Name" />
                        }
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="card-title mb-0 text-success">@animal.Name</h4>
                                <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">@animal.Category?.Name</span>
                            </div>

                            @if ((!string.IsNullOrEmpty(currentUserId) && animal.OwnerId == currentUserId) || User.IsInRole("Administrator"))
                            {
                                <div class="d-flex justify-content-end gap-2 mt-3">
                                    <a asp-action="Edit" asp-route-id="@animal.Id" class="text-success text-decoration-none" title="Редактирай">
                                        <i class="bi bi-pencil-fill fs-5"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@animal.Id" class="text-success text-decoration-none ms-2" title="Изтрий">
                                        <i class="bi bi-trash3-fill fs-5"></i>
                                    </a>
                                </div>
                            }

                            <h6 class="card-subtitle mb-3 text-muted">
                                <i class="bi bi-tag-fill text-success me-1"></i> @animal.Species
                                @if (!string.IsNullOrEmpty(animal.Breed))
                                {
                                    <span class="text-muted">• @animal.Breed</span>
                                }
                            </h6>

                            @if (!string.IsNullOrEmpty(animal.Town))
                            {
                                <p class="card-text mb-3">
                                    <i class="bi bi-geo-alt-fill text-success me-1"></i>
                                    <strong>@animal.Town</strong>
                                </p>
                            }

                            <p class="card-text mb-3">
                                <i class="bi bi-telephone-fill text-success me-1"></i>
                                <strong>@animal.PhoneNumber</strong>
                            </p>

                            <p class="card-text">
                                <small class="text-muted">
                                    <i class="bi bi-chat me-1"></i> Търси приятел за игра
                                </small>
                            </p>

                            <p class="card-text text-truncate">@animal.Description</p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3 px-3">
                            <a asp-action="Details" asp-route-id="@animal.Id" class="btn btn-success w-100 py-2">
                                Детайли
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Animals pagination" class="mt-2">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-town="@Model.Town"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize">Назад</a>
                    </li>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(Model.Page == i ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-categoryId="@Model.CategoryId"
                               asp-route-town="@Model.Town"
                               asp-route-page="@i"
                               asp-route-pageSize="@Model.PageSize">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-town="@Model.Town"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize">Напред</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
