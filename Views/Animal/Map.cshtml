@model IEnumerable<Animatch.Models.Animal>
@{
    ViewData["Title"] = "Карта на животните";
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="fas fa-map-marked-alt text-warning me-2"></i> Карта на нашите приятели
            </h1>
            <p class="lead text-muted">Вижте къде се намират животните, които търсят своя нов дом!</p>
        </div>
    </div>
    
    <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
        <div class="card-body p-0">
            <div id="map" style="width: 100%; height: 600px;"></div>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn btn-outline-secondary px-5 py-3 rounded-pill shadow-sm">
            <i class="fas fa-arrow-left me-2"></i> Обратно към списъка
        </a>
    </div>
</div>

@section Scripts {
    <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
    <script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
    
    <style>
        .mapboxgl-popup-content {
            border-radius: 12px;
            padding: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.15);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .mapboxgl-popup-close-button {
            padding: 5px;
            line-height: normal;
        }
    </style>

    <script>
        const mapboxKey = '@ViewBag.MapboxKey';
        const mapContainer = document.getElementById('map');
        
        if (!mapboxKey || mapboxKey === '') {
            console.error('Mapbox key is missing!');
            const warning = document.createElement('div');
            warning.className = 'alert alert-danger m-5';
            warning.textContent = 'Mapbox API ключът липсва. Проверете .env файла.';
            mapContainer.appendChild(warning);
        } else {
            mapboxgl.accessToken = mapboxKey;
            
            const map = new mapboxgl.Map({
                container: 'map',
                style: 'mapbox://styles/mapbox/streets-v12',
                center: [25.4858, 42.7339],
                zoom: 6.5
            });

            
            map.addControl(new mapboxgl.NavigationControl());
            const createPopupContent = (animal) => {
                const wrapper = document.createElement('div');
                wrapper.className = 'text-center';

                const title = document.createElement('h6');
                title.className = 'fw-bold mb-1';
                title.textContent = animal.name ?? '';

                const species = document.createElement('p');
                species.className = 'small text-muted mb-2';
                species.textContent = animal.species ?? '';

                const detailsLink = document.createElement('a');
                detailsLink.className = 'btn btn-sm btn-primary w-100 rounded-pill';
                detailsLink.href = `/Animal/Details/${animal.id}`;
                detailsLink.textContent = 'Детайли';

                wrapper.appendChild(title);
                wrapper.appendChild(species);
                wrapper.appendChild(detailsLink);
                return wrapper;
            };

            const loadAnimals = async () => {
                try {
                    const response = await fetch('/api/animals?withCoordinates=true&page=1&pageSize=200', {
                        headers: { 'Accept': 'application/json' }
                    });

                    if (!response.ok) {
                        throw new Error('Cannot load animals');
                    }

                    const payload = await response.json();
                    const animals = payload.items ?? payload.Items ?? [];

                    const bounds = new mapboxgl.LngLatBounds();
                    let hasCoordinates = false;

                    animals.forEach(animal => {
                        const lat = animal.latitude ?? animal.Latitude;
                        const lng = animal.longitude ?? animal.Longitude;
                        if (lat != null && lng != null) {
                            hasCoordinates = true;

                            const popup = new mapboxgl.Popup({ offset: 25 })
                                .setDOMContent(createPopupContent({
                                    id: animal.id ?? animal.Id,
                                    name: animal.name ?? animal.Name,
                                    species: animal.species ?? animal.Species
                                }));

                            new mapboxgl.Marker({ color: '#ffc107' })
                                .setLngLat([lng, lat])
                                .setPopup(popup)
                                .addTo(map);

                            bounds.extend([lng, lat]);
                        }
                    });

                    if (hasCoordinates) {
                        map.fitBounds(bounds, { padding: 100, maxZoom: 14 });
                    } else {
                        const info = document.createElement('div');
                        info.className = 'alert alert-info m-4';
                        info.textContent = 'Няма намерени животни с координати.';
                        mapContainer.appendChild(info);
                    }
                } catch (error) {
                    console.error(error);
                    const errorBox = document.createElement('div');
                    errorBox.className = 'alert alert-danger m-4';
                    errorBox.textContent = 'Възникна проблем при зареждане на данните от API.';
                    mapContainer.appendChild(errorBox);
                }
            };

            loadAnimals();
        }
    </script>
}
