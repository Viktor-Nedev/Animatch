@{
    ViewData["Title"] = "500 Server Error";
}

<div class="container mt-5">
    <div class="card border-0 shadow-lg text-center p-5">
        <div class="mb-3">
            <span class="display-2 fw-bold text-danger">500</span>
        </div>
        <h2 class="fw-bold mb-3">Възникна вътрешна грешка</h2>
        <p class="text-muted mb-4">В момента не можем да обработим заявката. Опитай отново след малко.</p>
        <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a asp-controller="Home" asp-action="Index" class="btn btn-success">Начало</a>
            <a asp-controller="Animal" asp-action="Index" class="btn btn-outline-secondary">Към обявите</a>
        </div>
    </div>
</div>
