<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Animatch</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Animatch.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body>
@{
    var path = Context.Request.Path;
    var isAuthPage = path.StartsWithSegments("/Identity/Account/Login")
        || path.StartsWithSegments("/Identity/Account/Register");
}
    <div class="layout-shell">
        @if (!isAuthPage)
        {
            <partial name="_NavbarPartial" />
        }
        <div class="container layout-content">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
        @if (!isAuthPage)
        {
            <partial name="_FooterPartial" />
        }
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
