<header class="site-header">
    <nav class="navbar navbar-expand-lg navbar-dark site-navbar py-2">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Animatch logo" class="navbar-logo" />
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavigation">
                <ul class="navbar-nav nav-pills-gap flex-grow-1 ms-lg-3 mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link nav-chip" asp-area="" asp-controller="Animal" asp-action="Index">
                            <i class="fas fa-paw"></i>
                            <span>Обяви</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-chip" asp-area="" asp-controller="Animal" asp-action="Map">
                            <i class="fas fa-map-marked-alt"></i>
                            <span>Карта</span>
                        </a>
                    </li>
                    @if (User.IsInRole("Administrator"))
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-chip" asp-area="Admin" asp-controller="Events" asp-action="Index">
                                <i class="fas fa-calendar-check"></i>
                                <span>Събития</span>
                            </a>
                        </li>
                    }
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link nav-chip" asp-area="" asp-controller="Requests" asp-action="MyRequests">
                                <i class="fas fa-clipboard-list"></i>
                                <span>Заявки</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-chip" asp-area="" asp-controller="Animal" asp-action="Profile">
                                <i class="fas fa-user-circle"></i>
                                <span>Профил</span>
                            </a>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
</header>
