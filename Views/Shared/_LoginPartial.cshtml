@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav ms-lg-3 auth-nav gap-2 align-items-lg-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link nav-chip nav-chip--accent" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="fas fa-user"></i>
            <span>@User.Identity?.Name</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="d-inline" method="post" asp-antiforgery="true" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link nav-chip nav-chip--logout border-0 bg-transparent">
                <i class="fas fa-right-from-bracket"></i>
                <span>Изход</span>
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link nav-chip" asp-area="Identity" asp-page="/Account/Register">
            <i class="fas fa-user-plus"></i>
            <span>Регистрация</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link nav-chip nav-chip--accent" asp-area="Identity" asp-page="/Account/Login">
            <i class="fas fa-right-to-bracket"></i>
            <span>Вход</span>
        </a>
    </li>
}
</ul>
