@model IEnumerable<Animatch.Models.Category>
@{
    ViewData["Title"] = "Категории";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Категории</h2>
        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-success">Нова категория</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Име</th>
                <th style="width: 160px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Name</td>
                    <td class="text-end">
                        @if (User.IsInRole("Administrator"))
                        {
                            <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-outline-primary btn-sm">Редактирай</a>
                            <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-outline-danger btn-sm ms-1">Изтрий</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
